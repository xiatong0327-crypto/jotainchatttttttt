{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jotainchatttttttt",
  "version": "0.1.5-open-finder",
  "identifier": "com.jotain.jotainchatttttttt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend-dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "jotainchatttttttt",
        "width": 1000,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "public.app-category.social-networking",
    "copyright": "Copyright © jotain",
    "shortDescription": "LAN chat + file transfer for macOS",
    "longDescription": "jotainchatttttttt is a local Wi-Fi LAN chat and file transfer app for Mac. Discover peers on the same network, message 1:1, and send files with receive confirmation. No accounts, no cloud, no automatic updates.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
